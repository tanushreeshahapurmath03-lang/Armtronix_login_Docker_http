# Local dev environment for backend (no logic changes)
# Use the same ports as docker-compose: backend 5002

# Backend listen port
PORT=5002

# JWT secret for auth
JWT_SECRET=change_me_local

# Frontend origin for CORS/socket.io
VITE_FRONTEND_URL=http://192.168.1.72:5176

# Mongo connection (edit if your Mongo uses different DB/user/credentials)
# If Mongo is running on the same host:
VITE_MONGO_URI=mongodb://127.0.0.1:27017/employee-auth
# Alternative (Mongo in same LAN, adjust if needed):
# VITE_MONGO_URI=mongodb://192.168.1.72:27017/employee-auth

